<body>
    <div class="hero">

    <div class="overlay">

        <h1>🏆 Copa Mundial de la FIFA 2026</h1>

        <p class="subtitulo">
            Estados Unidos • México • Canadá
        </p>

        <div class="botones">
            <a href="/">🏠 Inicio</a>
            <a href="/agregar">➕ Agregar País</a>
